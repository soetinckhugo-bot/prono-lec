# Pour production (Supabase/Neon) : remplace par l'URL PostgreSQL
# Avec Supabase, utilise le port 6543 (Transaction pooler) pour Vercel
DATABASE_URL="postgresql://postgres:PASSWORD@db.xxxxxxx.supabase.co:6543/postgres"

NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"
